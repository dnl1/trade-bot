# ── Binance ───────────────────────────────────────────────────────────────────
# Required: Binance API key
BINANCE_API_KEY=your_binance_api_key_here

# Use ONE of the two authentication methods:
# Option A — HMAC secret key (simpler)
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Option B — RSA private key (more secure, recommended by Binance)
# IMPORTANT: use an absolute path — docker-compose does NOT expand ~ (tilde)
# BINANCE_RSA_KEY_PATH=/opt/trade-bot/binance_key.pem   ✔ correct
# BINANCE_RSA_KEY_PATH=~/.ssh/id_binance_rsa             ✗ will NOT work
# BINANCE_SECRET_KEY=   # leave empty when using RSA

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── Telegram (optional — alerts and logs on your phone) ──────────────────────
TELEGRAM_BOT_ID=          # e.g. 1969271745:AAECd5SxpyERKl6T2TYxs4R5PptwyPyA7lw
TELEGRAM_CHAT_ID=         # e.g. 436374967
